{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Extension - Run Mode",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "${defaultBuildTask}"
    },
    {
      "name": "Extension - Test Mode",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "${defaultBuildTask}",
      "env": {
        "TURBO_RUN_MODE": "test"
      }
    },
    {
      "name": "VSCode Integration Tests",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--disable-extensions",
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/out/mocha-tests/testsRunner"
      ],
      "outFiles": ["${workspaceFolder}/out/mocha-tests/**/*.js"],
      "preLaunchTask": "${defaultBuildTask}"
    }
  ]
}
